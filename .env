# NextAuth.js Secret Key - Used to encrypt JWT tokens
# Generate a new one with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here

# NextAuth.js URL - The base URL of your application
NEXTAUTH_URL=https://drsi.ai/
NEXT_PUBLIC_APP_URL=https://drsi.ai/

# API URL for authentication
API_URL=http://localhost:3000/api

# Backend API Base URL (for static export, only NEXT_PUBLIC_BACKEND_URL is used)
# BACKEND_URL=https://drsi.ai  # Not used in static export
NEXT_PUBLIC_BACKEND_URL=https://drsi.ai

# AWS Configuration (for deployment)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=eu-central-1

# S3 Bucket Names
S3_BUCKET_NAME_DEV=dev.yatalb.com
S3_BUCKET_NAME_PROD=app.yatalb.com

# CloudFront Distribution IDs (optional, for future CDN setup)
# CLOUDFRONT_DISTRIBUTION_ID_DEV=your-cloudfront-distribution-id-dev
# CLOUDFRONT_DISTRIBUTION_ID_PROD=your-cloudfront-distribution-id-prod

# Deployment URLs (Set during deployment)
# NEXTAUTH_URL: Uses custom domains (https://dev.yatalb.com, https://app.yatalb.com)
# NEXT_PUBLIC_BACKEND_URL: Uses API_URL_DEV/PROD GitHub secrets

# Static Export Limitations:
# - Database connections (DATABASE_URL) are not supported
# - Google OAuth (GOOGLE_CLIENT_ID/SECRET) is not supported
# - Server-side authentication (NextAuth.js) is not supported
# - API routes are not supported

# Add any other environment variables your application needs below